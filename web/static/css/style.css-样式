* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: #333;
    min-height: 100vh;
    padding: 20px;
}

.container {
    max-width: 1400px;
    margin: 0 auto;
}

/* 头部 */
.header {
    background: white;
    padding: 40px 20px;
    border-radius: 10px;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    margin-bottom: 30px;
    text-align: center;
}

.header h1 {
    font-size: 2.5em;
    color: #667eea;
    margin-bottom: 10px;
}

.subtitle {
    font-size: 1.1em;
    color: #666;
}

/* 统计卡片 */
.stats-section {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 20px;
    margin-bottom: 30px;
}

.stat-card {
    background: white;
    padding: 20px;
    border-radius: 10px;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    display: flex;
    align-items: center;
    gap: 20px;
    transition: transform 0.3s ease;
}

.stat-card:hover {
    transform: translateY(-5px);
}

.stat-card.flame {
    border-left: 4px solid #ff6b6b;
}

.stat-card.smoke {
    border-left: 4px solid #95a5a6;
}

.stat-card.alert {
    border-left: 4px solid #f39c12;
}

.stat-icon {
    font-size: 2.5em;
}

.stat-content {
    flex: 1;
}

.stat-value {
    font-size: 2em;
    font-weight: bold;
    color: #667eea;
}

.stat-label {
    color: #999;
    font-size: 0.9em;
}

/* 主内容区 */
.main-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 30px;
}

.upload-section, .result-section {
    background: white;
    padding: 20px;
    border-radius: 10px;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
}

.upload-section h2, .result-section h2 {
    margin-bottom: 20px;
    color: #667eea;
}

/* 上传区域 */
.upload-area {
    border: 2px dashed #667eea;
    border-radius: 8px;
    padding: 40px;
    text-align: center;
    cursor: pointer;
    transition: all 0.3s ease;
    margin-bottom: 15px;
}

.upload-area:hover {
    background: #f8f9ff;
    border-color: #764ba2;
}

.upload-area.dragover {
    background: #f0f0ff;
    border-color: #764ba2;
}

.upload-icon {
    font-size: 3em;
    margin-bottom: 10px;
}

.upload-area p {
    font-size: 1.1em;
    margin-bottom: 5px;
}

.upload-area small {
    color: #999;
}

/* 按钮 */
.btn-primary {
    width: 100%;
    padding: 12px;
    background: #667eea;
    color: white;
    border: none;
    border-radius: 5px;
    font-size: 1em;
    cursor: pointer;
    transition: background 0.3s ease;
}

.btn-primary:hover:not(:disabled) {
    background: #764ba2;
}

.btn-primary:disabled {
    background: #ccc;
    cursor: not-allowed;
}

/* 检测结果 */
.result-container {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 300px;
}

.placeholder {
    color: #999;
    text-align: center;
}

.detection-result {
    text-align: center;
}

.detection-result img {
    max-width: 100%;
    border-radius: 5px;
    margin-bottom: 15px;
}

.detection-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    margin-top: 15px;
}

.stat-item {
    background: #f8f9ff;
    padding: 10px;
    border-radius: 5px;
    text-align: center;
}

.stat-item-label {
    font-size: 0.9em;
    color: #666;
}

.stat-item-value {
    font-size: 1.5em;
    font-weight: bold;
    color: #667eea;
}

/* 图表 */
.chart-section {
    background: white;
    padding: 20px;
    border-radius: 10px;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    margin-bottom: 30px;
}

.chart-section h2 {
    margin-bottom: 20px;
    color: #667eea;
}

.chart-container {
    position: relative;
    height: 300px;
}

/* 表格 */
.history-section, .alerts-section {
    background: white;
    padding: 20px;
    border-radius: 10px;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    margin-bottom: 30px;
}

.history-section h2, .alerts-section h2 {
    margin-bottom: 20px;
    color: #667eea;
}

.history-table {
    width: 100%;
    border-collapse: collapse;
}

.history-table thead {
    background: #f8f9ff;
}

.history-table th {
    padding: 12px;
    text-align: left;
    color: #667eea;
    font-weight: bold;
}

.history-table td {
    padding: 12px;
    border-bottom: 1px solid #eee;
}

.history-table tbody tr:hover {
    background: #f8f9ff;
}

.btn-view {
    color: #667eea;
    cursor: pointer;
    text-decoration: underline;
}

.btn-view:hover {
    color: #764ba2;
}

/* 报警容器 */
.alerts-container {
    display: flex;
    flex-direction: column;
    gap: 10px;
}

.alert-item {
    padding: 15px;
    background: #fff3cd;
    border-left: 4px solid #f39c12;
    border-radius: 5px;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.alert-item.flame {
    background: #fee;
    border-left-color: #ff6b6b;
}

.alert-time {
    color: #666;
    font-size: 0.9em;
}

/* 响应式设计 */
@media (max-width: 768px) {
    .main-content {
        grid-template-columns: 1fr;
    }
    
    .header h1 {
        font-size: 1.8em;
    }
    
    .stats-section {
        grid-template-columns: 1fr 1fr;
    }
}
