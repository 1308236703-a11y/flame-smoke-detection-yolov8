@app.route('/api/detect', methods=['POST'])
def detect():
    """上传图片进行检测"""
    if 'file' not in request.files:
        return jsonify({'error': '未提供文件'}), 400
    
    file = request.files['file']
    if file.filename == '':
        return jsonify({'error': '文件名为空'}), 400
    
    try:
        # 保存上传的文件
        filename = f"upload_{datetime.now().strftime('%Y%m%d_%H%M%S')}.jpg"
        upload_path = f'./data/uploads/{filename}'
        Path('./data/uploads').mkdir(parents=True, exist_ok=True)
        file.save(upload_path)
        
        # 进行检测
        result = detector.detect_image(upload_path)
        
        if not result:
            return jsonify({'error': '检测失败'}), 500
        
        # 保存结果图片
        result_filename = f"result_{datetime.now().strftime('%Y%m%d_%H%M%S')}.jpg"
        result_path = f'./results/{result_filename}'
        cv2.imwrite(result_path, result['image'])
        
        # 计算平均置信度
        avg_conf = result['confidence_avg']
        
        # 保存到数据库
        detection_id = db.save_detection(
            image_path=upload_path,
            flame_count=result['flame_count'],
            smoke_count=result['smoke_count'],
            confidence_avg=avg_conf,
            result_image_path=result_path,
            model_name='yolov8n',
            processing_time=result['processing_time']
        )
        
        # 检查是否需要报警
        if result['flame_count'] > 0 or result['smoke_count'] > 0:
            alert_type = '火焰' if result['flame_count'] > 0 else '烟雾'
            alert_manager.trigger_alert(
                detection_id=detection_id,
                flame_count=result['flame_count'],
                smoke_count=result['smoke_count'],
                confidence=avg_conf,
                image_path=upload_path
            )
            
            # 保存报警到数据库
            db.save_alert(
                detection_id=detection_id,
                alert_type=alert_type,
                message=f'检测到{alert_type}: 置信度 {avg_conf:.2f}',
                phone_number=os.getenv('ALERT_PHONE_NUMBER', '+1234567890'),
                sms_sent=True,
                confidence=avg_conf
            )
        
        # 转换检测图片为base64
        with open(result_path, 'rb') as img_file:
            img_base64 = base64.b64encode(img_file.read()).decode('utf-8')
        
        return jsonify({
            'id': detection_id,
            'flame_count': result['flame_count'],
            'smoke_count': result['smoke_count'],
            'confidence_avg': avg_conf,
            'processing_time_ms': result['processing_time'],
            'result_image': f'data:image/jpeg;base64,{img_base64}',
            'timestamp': datetime.now().isoformat(),
            'detections': result['detections']
        })
    
    except Exception as e:
        return jsonify({'error': str(e)}), 500

@app.route('/api/detection/<int:detection_id>', methods=['GET'])
def get_detection(detection_id):
    """获取单个检测详情"""
